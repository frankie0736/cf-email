{
  "name": "cf-email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.17",
  "scripts": {
    "check": "tsc --noEmit",
    "cf-typegen": "mkdir -p .home && HOME=$PWD/.home wrangler types",
    "db:migrate:local": "mkdir -p .home && HOME=$PWD/.home wrangler d1 migrations apply brightex-mailbox --local",
    "db:migrate:remote": "wrangler d1 migrations apply brightex-mailbox --remote",
    "deploy": "wrangler deploy",
    "dev": "mkdir -p .home && HOME=$PWD/.home wrangler dev",
    "verify:local": "bash ./scripts/verify-local.sh"
  },
  "dependencies": {
    "postal-mime": "^2.6.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "wrangler": "^4.68.0"
  }
}
